# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        VOLTAGE Platform — .env.example                       ║
# ║  Скопируй этот файл: cp .env.example .env  и заполни свои значения           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Django ───────────────────────────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Локальная разработка: True | Production: False
DEBUG=True

# Локальная разработка: localhost,127.0.0.1
# Production: your-domain.com,admin.your-domain.com,api.your-domain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=voltage
POSTGRES_USER=voltage_user
# Сгенерировать: openssl rand -hex 24
POSTGRES_PASSWORD=your-password-here
DATABASE_URL=postgresql://voltage_user:your-password-here@db:5432/voltage

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=Europe/Moscow

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=Europe/Moscow

# ─── Domain ───────────────────────────────────────────────────────────────────
# Локальная разработка: localhost
# Production: your-domain.com
DOMAIN=localhost

# ─── Frontend API URL ─────────────────────────────────────────────────────────
# Локальная разработка (через Caddy на порту 80):
VITE_API_URL=http://localhost/api
# Production (раскомментируй и замени домен):
# VITE_API_URL=https://your-domain.com/api

# ─── Безопасность ─────────────────────────────────────────────────────────────
# Секретный ключ для внутреннего API между ботами и бэкендом
# Сгенерировать: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret

# URL путь к панели администратора
# Для безопасности можно использовать нестандартный путь
# Локальная разработка: /admin
# Production пример: /admin или /secretpanel или /a8f3k2
# ВАЖНО: этот же путь укажи в Caddyfile (см. Caddyfile.example)
ADMIN_PATH=/admin

# ─── Telegram бот ─────────────────────────────────────────────────────────────
# Получить у @BotFather в Telegram — команда /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Twitch бот ───────────────────────────────────────────────────────────────
# Зарегистрировать приложение на dev.twitch.tv/console
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# ID Twitch аккаунта бота
# Получить: https://api.twitch.tv/helix/users?login=ИМЯ_БОТА
TWITCH_BOT_ID=your-bot-twitch-id

# ID Twitch аккаунта стримера (владельца канала)
# Получить: https://api.twitch.tv/helix/users?login=ИМЯ_СТРИМЕРА
TWITCH_OWNER_ID=your-twitch-id

# OAuth callback URL
# Локальная разработка: http://localhost/oauth/callback
# Production: https://your-domain.com/oauth/callback
TWITCH_REDIRECT_URI=http://localhost/oauth/callback

# ─── Системный пользователь API ───────────────────────────────────────────────
# Пароль для системного пользователя voltage_bot
# Сгенерировать: openssl rand -hex 16
BOT_PASSWORD=your-bot-password

# JWT токен — оставь пустым, генерируется автоматически
BOT_JWT_TOKEN=

# ─── Владелец платформы ───────────────────────────────────────────────────────
# Telegram ID владельца — для автоматической выдачи роли Owner при первом входе
# Узнать свой ID: написать @userinfobot в Telegram
OWNER_TELEGRAM_ID=your-telegram-id

# ─── Steam (после MVP) ────────────────────────────────────────────────────────
# Получить на steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# ─── LisSkins / VoltageDrops (после MVP) ─────────────────────────────────────
# API ключ для автоматической доставки скинов
# LISSKINS_API_KEY=

# ─── GSI — CS2 Game State Integration (после MVP) ────────────────────────────
# Секретный токен для GSI — любая случайная строка
# GSI_TOKEN=your-gsi-token

# ─── AI интеграция (после MVP) ────────────────────────────────────────────────
# Выбери одного провайдера или несколько
# ANTHROPIC_API_KEY=       # Claude
# OPENAI_API_KEY=          # ChatGPT
# DEEPSEEK_API_KEY=        # DeepSeek
# GROK_API_KEY=            # Grok
