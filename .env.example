# ─── Django ───────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=voltage
POSTGRES_USER=voltage_user
POSTGRES_PASSWORD=your-password-here
DATABASE_URL=postgresql://voltage_user:your-password-here@db:5432/voltage

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Domain ───────────────────────────────────────────────
DOMAIN=localhost

# ─── Telegram бот ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Twitch бот ───────────────────────────────────────────
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
TWITCH_BOT_ID=your-bot-twitch-id
TWITCH_OWNER_ID=your-twitch-id
TWITCH_REDIRECT_URI=http://localhost:4343/oauth/callback
TWITCH_DB_PATH=/app/twitch_tokens.db

# ─── Бот-пользователь для API ─────────────────────────────
# Пароль для системного пользователя voltage_bot
BOT_PASSWORD=your-bot-password
# JWT токен (генерируется автоматически, не нужно менять вручную)
BOT_JWT_TOKEN=

# ─── Steam ────────────────────────────────────────────────
# STEAM_API_KEY=

# ─── LisSkins / VoltageDrops ──────────────────────────────
# LISSKINS_API_KEY=

# ─── AI Модерация ─────────────────────────────────────────
# ANTHROPIC_API_KEY=