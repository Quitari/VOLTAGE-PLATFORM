# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=voltage
POSTGRES_USER=voltage_user
POSTGRES_PASSWORD=your-password-here
DATABASE_URL=postgresql://voltage_user:your-password-here@db:5432/voltage

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=Europe/Moscow

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=Europe/Moscow

# ─── Domain ───────────────────────────────────────────────────────────────────
# Локальная разработка: localhost
# Production: ваш домен, например example.com
DOMAIN=localhost

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Локальная разработка:
VITE_API_URL=http://localhost:8000/api
# Production (раскомментируй):
# VITE_API_URL=https://api.your-domain.com

# ─── Telegram бот ─────────────────────────────────────────────────────────────
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Twitch бот ───────────────────────────────────────────────────────────────
# Получить на dev.twitch.tv/console
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
# ID Twitch аккаунта бота (larkin_bot)
TWITCH_BOT_ID=your-bot-twitch-id
# ID Twitch аккаунта стримера (владельца канала)
TWITCH_OWNER_ID=your-twitch-id
# OAuth callback — для локала: http://localhost:4343/oauth/callback
# Для production: https://twitch.your-domain.com/oauth/callback
TWITCH_REDIRECT_URI=http://localhost:4343/oauth/callback
# Путь к SQLite базе токенов Twitch
TWITCH_DB_PATH=/app/twitch_tokens.db

# ─── Системный пользователь API ───────────────────────────────────────────────
# Пароль для voltage_bot — создать через manage.py после деплоя
BOT_PASSWORD=your-bot-password
# JWT токен генерируется автоматически, оставь пустым
BOT_JWT_TOKEN=

# ─── Владелец платформы ───────────────────────────────────────────────────────
# Telegram ID владельца — для автоматической выдачи роли Owner
# Узнать свой ID: написать @userinfobot в Telegram
OWNER_TELEGRAM_ID=your-telegram-id

# ─── Steam ────────────────────────────────────────────────────────────────────
# Получить на steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# ─── LisSkins / VoltageDrops ──────────────────────────────────────────────────
# API ключ для доставки скинов
# LISSKINS_API_KEY=

# ─── GSI (CS2 Game State Integration) ────────────────────────────────────────
# Секретный токен для GSI — любая случайная строка
# GSI_TOKEN=your-gsi-token

# ─── AI Модерация ─────────────────────────────────────────────────────────────
# Anthropic Claude API для автомодерации
# ANTHROPIC_API_KEY=