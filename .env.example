# ─── Django ───────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=voltage
POSTGRES_USER=voltage_user
POSTGRES_PASSWORD=your-password-here
DATABASE_URL=postgresql://voltage_user:your-password-here@db:5432/voltage

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Domain ───────────────────────────────────────────────
DOMAIN=localhost

# ─── Telegram бот ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Twitch бот ───────────────────────────────────────────
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
TWITCH_BOT_ID=your-bot-twitch-id
TWITCH_OWNER_ID=your-twitch-id
TWITCH_REDIRECT_URI=http://localhost:4343/oauth/callback
TWITCH_DB_PATH=/app/twitch_tokens.db

# ─── Бот-пользователь для API ─────────────────────────────
BOT_PASSWORD=your-bot-password
BOT_JWT_TOKEN=

# ─── Frontend ─────────────────────────────────────────────
# Для локальной разработки:
VITE_API_URL=http://localhost:8000/api
# Для production (раскомментируй и замени домен):
# VITE_API_URL=https://api.your-domain.com

# ─── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=Europe/Moscow

# ─── Timezone ─────────────────────────────────────────────
TZ=Europe/Moscow

# ─── Steam ────────────────────────────────────────────────
# STEAM_API_KEY=

# ─── LisSkins / VoltageDrops ──────────────────────────────
# LISSKINS_API_KEY=

# ─── AI Модерация ─────────────────────────────────────────
# ANTHROPIC_API_KEY=